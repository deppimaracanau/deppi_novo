```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
.gradle/

# Python specific
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Angular and Build Cache
.angular/

# AI Agent Instructions and Workflows
.agents/
.agent/

# Linter and hints
.hintrc

# Old bootstrap maps and system noise
cargahoraria/**
cargahoraria/bootstrap/**/*.map
cargahoraria/favicon.ico
```